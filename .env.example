# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=voting
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=voting-group
KAFKA_AUTO_OFFSET_RESET=earliest

# Kafka Topics
KAFKA_VOTERS_TOPIC=voters_topic
KAFKA_CANDIDATES_TOPIC=candidates_topic
KAFKA_VOTES_TOPIC=votes_topic
KAFKA_AGGREGATED_VOTES_TOPIC=aggregated_votes_per_candidate
KAFKA_AGGREGATED_TURNOUT_TOPIC=aggregated_turnout_by_location

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_APP_NAME=ElectionAnalysis
SPARK_CHECKPOINT_DIR=checkpoints
POSTGRESQL_JAR_PATH=postgresql-42.7.2.jar
SPARK_WATERMARK_DURATION=1 minute

# Application Configuration
RANDOM_SEED=42
NUM_CANDIDATES=3
NUM_VOTERS=500
VOTING_DELAY_SECONDS=0.2
RANDOMUSER_API_URL=https://randomuser.me/api/?nat=gb
PARTIES=Management Party,Savior Party,Tech Republic Party